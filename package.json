{
    "name": "felipillo",
    "version": "1.0.0",
    "description": "Premium Spare Parts Management System",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"wait-on http://localhost:5173 && electron .\"",
        "dev:backend": "cd backend && npm run dev",
        "dev:frontend": "cd frontend && npm run dev",
        "build:frontend": "cd frontend && npm run build",
        "dist": "npm run build:frontend && electron-packager . \"La casa de los retenes S&G\" --platform=win32 --arch=x64 --out=dist_electron --overwrite",
        "build:electron": "node build.js",
        "postinstall": "cd backend && npm install && cd ../frontend && npm install"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "concurrently": "^8.2.2",
        "electron-is-dev": "^2.0.0",
        "pdfkit": "^0.18.0",
        "wait-on": "^7.2.0"
    },
    "devDependencies": {
        "electron": "^28.2.0",
        "electron-builder": "^24.9.1",
        "electron-packager": "^17.1.2"
    },
    "build": {
        "appId": "com.spareparts.store",
        "productName": "La casa de los retenes S y G",
        "asar": true,
        "directories": {
            "output": "dist_electron"
        },
        "win": {
            "target": [
                "nsis",
                "portable"
            ],
            "icon": "icon.png"
        },
        "nsis": {
            "oneClick": true,
            "perMachine": false,
            "allowToChangeInstallationDirectory": false,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "La Casa de los Retenes S y G"
        },
        "files": [
            "main.js",
            "frontend/dist/**/*",
            "node_modules/**/*"
        ],
        "extraResources": [
            {
                "from": "backend",
                "to": "backend"
            },
            {
                "from": "frontend/dist",
                "to": "frontend/dist"
            }
        ]
    }
}
